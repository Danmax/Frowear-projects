# ── Admin ────────────────────────────────────────────────────
FW_ADMIN_KEY=change-this-admin-key
FW_WEBHOOK_SECRET=change-this-webhook-secret

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=u130206374_FrowearProd
DB_USER=u130206374_Frowear
DB_PASS=password

# ── App ───────────────────────────────────────────────────────
# Public base URL — no trailing slash — used in email verification links
APP_URL=https://frowear.com

# ── Email (from address) ──────────────────────────────────────
MAIL_FROM_ADDRESS=info@frowear.com
MAIL_FROM_NAME=Frowear Productions

# ── SMTP (required on Hostinger — PHP mail() alone won't work) ─
# Find these in Hostinger hPanel → Email → Email Accounts → Manage
# Hostinger SMTP host is usually: mail.hostinger.com
MAIL_SMTP_HOST=mail.hostinger.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=ssl
MAIL_SMTP_USER=info@frowear.com
MAIL_SMTP_PASS=your-email-account-password
